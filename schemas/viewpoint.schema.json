{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jklop3841/human/schemas/viewpoint.schema.json",
  "title": "Human Viewpoint",
  "description": "A versioned, attributable and contestable personal viewpoint.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "author",
    "created_at",
    "version",
    "status",
    "topics",
    "content_types",
    "claim",
    "confidence",
    "agent_usage"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^HUMAN-[A-Z0-9]+-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "enum": ["raw", "draft", "active", "contested", "revised", "retired"]
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["fact", "inference", "value", "experience"]
      }
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Author self-assessment, not a statistical probability."
    },
    "author_confirmed": {
      "type": "boolean",
      "default": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "summary"],
        "properties": {
          "type": {
            "enum": ["source", "case", "experience", "observation", "data"]
          },
          "summary": {
            "type": "string"
          },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "observed_at": {
            "type": ["string", "null"],
            "format": "date"
          }
        }
      }
    },
    "counterarguments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bias_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string"
    },
    "revision_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agent_usage": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
