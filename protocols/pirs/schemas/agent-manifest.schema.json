{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jklop3841/human/protocols/pirs/schemas/agent-manifest.schema.json",
  "title": "PIRS Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "agent_id", "name", "version", "publisher", "artifact_digest", "protocols", "capabilities", "lineage", "verification", "legal_principal"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "agent_id": {"type": "string", "pattern": "^pirs:[^\\s]+$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "publisher": {
      "type": "object",
      "required": ["id", "display_name"],
      "properties": {
        "id": {"type": "string"},
        "display_name": {"type": "string"}
      }
    },
    "legal_principal": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {"enum": ["person", "organization"]},
        "id": {"type": "string"},
        "jurisdiction": {"type": "string"}
      }
    },
    "artifact_digest": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "source_uri": {"type": "string", "format": "uri"},
    "protocols": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["protocol_id", "version", "artifact_digest"],
        "properties": {
          "protocol_id": {"type": "string"},
          "version": {"type": "string"},
          "artifact_digest": {"type": "string"}
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "claim_status"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "claim_status": {"enum": ["self-declared", "tested", "independently-verified"]},
          "evidence_uri": {"type": "string", "format": "uri"}
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["is_fork"],
      "properties": {
        "is_fork": {"type": "boolean"},
        "parent_agent_id": {"type": ["string", "null"]},
        "parent_version": {"type": ["string", "null"]},
        "parent_digest": {"type": ["string", "null"]},
        "patch_digest": {"type": ["string", "null"]},
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "role"],
            "properties": {
              "id": {"type": "string"},
              "role": {"type": "string"}
            }
          }
        }
      }
    },
    "revenue_policy_uri": {"type": "string", "format": "uri"},
    "verification": {
      "type": "object",
      "required": ["signature_method", "signature_uri", "revocation_uri"],
      "properties": {
        "signature_method": {"type": "string"},
        "signature_uri": {"type": "string", "format": "uri"},
        "build_attestation_uri": {"type": "string", "format": "uri"},
        "revocation_uri": {"type": "string", "format": "uri"}
      }
    }
  }
}

